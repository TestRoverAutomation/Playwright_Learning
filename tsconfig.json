{
  "compilerOptions": {
    /* === Core Language & Module Settings === */
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* === Strictness & Safety === */
    "strict": true,
    "skipLibCheck": true,

    /* === Output & Paths === */
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@utils/*": ["./tests/UI_Test/utils/*"],
      "@steps/*": ["./tests/UI_Test/steps/*"],
      "@fixtures/*": ["./tests/UI_Test/fixture/*"]
    },

    /* === Types === */
    "types": ["node"],
    "typeRoots": ["./types", "./node_modules/@types"],

    /* === Experimental === */
    "experimentalDecorators": true
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts",
    "playwrightapi.config.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"]
}
